{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "clientapp": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public/"
              }
            ],
            "externalDependencies": [
              "public/vendor/font-awesome/css/fontawesome-all.min.css",
              "public/css/font-electro.css",
              "public/vendor/animate.css/animate.min.css",
              "public/vendor/hs-megamenu/src/hs.megamenu.css",
              "public/vendor/malihu-custom-scrollbar-plugin/jquery.mCustomScrollbar.css",
              "public/vendor/fancybox/jquery.fancybox.css",
              "public/vendor/slick-carousel/slick/slick.css",
              "public/vendor/bootstrap-select/dist/css/bootstrap-select.min.css",

              "public/vendor/jquery/dist/jquery.min.js",
              "public/vendor/jquery-migrate/dist/jquery-migrate.min.js",
              "public/vendor/popper.js/dist/umd/popper.min.js",
              "public/vendor/bootstrap/bootstrap.min.js",
              "public/vendor/appear.js",
              "public/vendor/jquery.countdown.min.js",
              "public/vendor/hs-megamenu/src/hs.megamenu.js",
              "public/vendor/svg-injector/dist/svg-injector.min.js",
              "public/vendor/malihu-custom-scrollbar-plugin/jquery.mCustomScrollbar.concat.min.js",
              "public/vendor/jquery-validation/dist/jquery.validate.min.js",
              "public/vendor/fancybox/jquery.fancybox.min.js",
              "public/vendor/typed.js/lib/typed.min.js",
              "public/vendor/slick-carousel/slick/slick.js",
              "public/vendor/bootstrap-select/dist/js/bootstrap-select.min.js",
              "public/js/hs.core.js",
              "public/js/components/hs.countdown.js",
              "public/js/components/hs.header.js",
              "public/js/components/hs.hamburgers.js",
              "public/js/components/hs.unfold.js",
              "public/js/components/hs.focus-state.js",
              "public/js/components/hs.malihu-scrollbar.js",
              "public/js/components/hs.validation.js",
              "public/js/components/hs.fancybox.js",
              "public/js/components/hs.onscroll-animation.js",
              "public/js/components/hs.slick-carousel.js",
              "public/js/components/hs.show-animation.js",
              "public/js/components/hs.svg-injector.js",
              "public/js/components/hs.go-to.js",
              "public/js/components/hs.selectpicker.js"
            ],
            "styles": [
              "./public/js/vendor/font-awesome/css/fontawesome-all.min.css",
              "./public/css/font-electro.css",
              "./public/js/vendor/animate.css/animate.min.css",
              "./public/js/vendor/hs-megamenu/src/hs.megamenu.css",
              "./public/js/vendor/malihu-custom-scrollbar-plugin/jquery.mCustomScrollbar.css",
              "./public/js/vendor/fancybox/jquery.fancybox.css",
              "./public/js/vendor/slick-carousel/slick/slick.css",
              "./public/js/vendor/bootstrap-select/dist/css/bootstrap-select.min.css"
            ],
            "scripts": [
              "./public/js/vendor/jquery/dist/jquery.min.js",
              "./public/js/vendor/jquery-migrate/dist/jquery-migrate.min.js",
              "./public/js/vendor/popper.js/dist/umd/popper.min.js",
              "./public/js/vendor/bootstrap/bootstrap.min.js",
              "./public/js/vendor/appear.js",
              "./public/js/vendor/jquery.countdown.min.js",
              "./public/js/vendor/hs-megamenu/src/hs.megamenu.js",
              "./public/js/vendor/svg-injector/dist/svg-injector.min.js",
              "./public/js/vendor/malihu-custom-scrollbar-plugin/jquery.mCustomScrollbar.concat.min.js",
              "./public/js/vendor/jquery-validation/dist/jquery.validate.min.js",
              "./public/js/vendor/fancybox/jquery.fancybox.min.js",
              "./public/js/vendor/typed.js/lib/typed.min.js",
              "./public/js/vendor/slick-carousel/slick/slick.js",
              "./public/js/vendor/bootstrap-select/dist/js/bootstrap-select.min.js",
              "./public/js/hs.core.js",
              "./public/js/components/hs.countdown.js",
              "./public/js/components/hs.header.js",
              "./public/js/components/hs.hamburgers.js",
              "./public/js/components/hs.unfold.js",
              "./public/js/components/hs.focus-state.js",
              "./public/js/components/hs.malihu-scrollbar.js",
              "./public/js/components/hs.validation.js",
              "./public/js/components/hs.fancybox.js",
              "./public/js/components/hs.onscroll-animation.js",
              "./public/js/components/hs.slick-carousel.js",
              "./public/js/components/hs.show-animation.js",
              "./public/js/components/hs.svg-injector.js",
              "./public/js/components/hs.go-to.js",
              "./public/js/components/hs.selectpicker.js"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1MB",
                  "maximumError": "3MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "1MB",
                  "maximumError": "3MB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.development.ts"
                }
              ]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "ssl": true,
            "sslCert": "ssl/localhost.pem",
            "sslKey": "ssl/localhost-key.pem",
            "port": 4201
          },
          "configurations": {
            "production": {
              "buildTarget": "clientapp:build:production"
            },
            "development": {
              "buildTarget": "clientapp:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}